{
  "name": "doc-ai-bot-api",
  "version": "1.0.0",
  "main": "dist/doc-ai-bot-api/src/server.js",
  "scripts": {
    "branch:init": "git push --set-upstream origin $(git branch --show-current)",
    "branch:main": "git switch main && git pull",
    "branch:new": "git checkout -b",
    "branch:sanity": "git add . && git commit -m 'wip' && git push",
    "server:dev": "tsx watch ./src/server.ts",
    "build": "tsc -b && vite build",
    "submodule:clone": "sh -c 'git submodule update --init $1' --",
    "submodule:pull": "sh -c 'git config -f .gitmodules submodule.$1.branch main && git submodule update --remote $1' --",
    "submodule:update": "sh -c 'cd ./src/$1 && git add . && git commit -m \"$2\" && git push' && cd ../.. && git add $1 && git commit -m \"$2\" && git push",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [],
  "author": "Albert_Fuchs",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@doc-ai-bot/infrastructure": "github:AlbertLeipzig/doc-ai-bot-infrastructure",
    "@doc-ai-bot/middlewares": "github:AlbertLeipzig/doc-ai-bot-middlewares",
    "@doc-ai-bot/services": "github:AlbertLeipzig/doc-ai-bot-services",
    "@doc-ai-bot/utils": "github:AlbertLeipzig/doc-ai-bot-utils",
    "@langchain/textsplitters": "^1.0.1",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-rate-limiter": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.25",
    "mongoose": "^9.2.1"
  },
  "devDependencies": {
    "@doc-ai-bot/types": "github:AlbertLeipzig/doc-ai-bot-types",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
